# FlowMind Server — copy to .env and fill in values

# HTTP API port
PORT=3001

# WebSocket collaboration port
WS_PORT=3002

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_32_byte_hex_string

# JWT expiry (e.g. 7d, 30d)
JWT_EXPIRES_IN=7d

# SQLite database file path (created automatically)
DB_PATH=./data/flowmind.db

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Share token default expiry (e.g. 7d, 30d, never)
SHARE_TOKEN_EXPIRES_IN=30d
