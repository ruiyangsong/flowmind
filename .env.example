# All variables are OPTIONAL — sensible defaults are baked into the image.
# Copy to `.env` and uncomment only what you want to override.

# Bind port (default 3000)
# PORT=3000

# SQLite database file. Inside Docker the default /data/flowmind.db is mounted
# as a named volume; outside Docker the default is ./data/flowmind.db.
# DB_PATH=/data/flowmind.db

# JWT signing key. If unset, FlowMind generates a 256-bit secret on first boot
# and persists it next to the DB. You only need to set this if you want
# tokens to remain valid after migrating to a different machine.
# JWT_SECRET=

# Token lifetime (e.g. "7d", "24h", "3600s"). Default 7d.
# JWT_EXPIRES_IN=7d

# Optional: override the base URL used to build share/collab links. By
# default share URLs are relative ("/share/<token>") so they work on any host.
# FRONTEND_URL=https://flow.example.com
